# ============================================
# PostgreSQL
# ============================================
DATABASE_URL=postgresql://admin:password@localhost:5432/wiki_db

# ============================================
# LLM
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# ============================================
# Embedding & Chunking
# ============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ============================================
# Elasticsearch
# ============================================
ES_HOST=http://localhost:9200
ES_USER=
ES_PASSWORD=
INDEX_NAME=wiki_chunks

# ============================================
# Wikipedia Crawler
# ============================================
# Phải >= 1.0 để tôn trọng Wikipedia rate limit policy
CRAWLER_RATE_LIMIT_SECONDS=1.0
# Số request đồng thời tối đa (an toàn ở mức 3-5 với Wikipedia)
CRAWLER_CONCURRENCY=3
CRAWLER_TIMEOUT_SECONDS=15.0
CRAWLER_RETRY_COUNT=3
CRAWLER_RETRY_BACKOFF=2.0
# Ngôn ngữ Wikipedia mặc định: en, vi, ja, zh, fr, de, ...
CRAWLER_WIKI_LANG=en
CRAWLER_USER_AGENT=wiki-rag-bot/1.0 (https://github.com/your-repo; your@email.com)

# Search / RAG Params
SEARCH_CANDIDATE_POOL=20
RRF_K=60
RAG_HYBRID_POOL=10
RAG_TOP_K_CONTEXT=3

# Embedding dims — phải khớp với EMBEDDING_MODEL
# all-MiniLM-L6-v2=384 | all-mpnet-base-v2=768
EMBEDDING_DIMS=384

# ============================================
# Redis Cache (optional)
# ============================================
REDIS_URL=redis://localhost:6379/0
